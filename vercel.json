{
  "rewrites": [
    { "source": "/api/command", "destination": "/api/command" },
    { "source": "/api/telemetry", "destination": "/api/telemetry" },
    { "source": "/api/ack", "destination": "/api/ack" },
    { "source": "/api", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Auth-Key" }
      ]
    }
  ]
}
